def web_search(query):
    """Search DuckDuckGo and return text results."""
    import urllib.parse

    url = (
        "https://api.duckduckgo.com/?q="
        + urllib.parse.quote(query)
        + "&format=json&no_html=1&skip_disambig=1"
    )
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "ai-cli/1.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())

        results = []
        if data.get("AbstractText"):
            results.append(f"Summary: {data['AbstractText']}")
            if data.get("AbstractURL"):
                results.append(f"Source: {data['AbstractURL']}")

        for item in data.get("RelatedTopics", [])[:5]:
            if isinstance(item, dict) and item.get("Text"):
                results.append(f"- {item['Text']}")
                if item.get("FirstURL"):
                    results.append(f"  {item['FirstURL']}")

        if not results:
            return f"No results found for: {query}"
        return "\n".join(results)
    except Exception as e:
        return f"[Search error: {e}]"


def c(color, text):
    if sys.stdout.isatty():
        return f"{COLORS.get(color, '')}{text}{COLORS['reset']}"
    return text


class Spinner:
    _frames = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

    def __init__(self, label="Thinking"):
        self._label = label
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._spin, daemon=True)

    def _spin(self):
        if not sys.stdout.isatty():
            return
        i = 0
        while not self._stop.is_set():
            frame = self._frames[i % len(self._frames)]
            print(
                f"\r{c('dim', frame + ' ' + self._label + '...')}", end="", flush=True
            )
            i += 1
            time.sleep(0.08)

    def __enter__(self):
        self._thread.start()
        return self

    def stop(self):
        """Non-blocking stop: signal thread and clear line immediately."""
        if not self._stop.is_set():
            self._stop.set()
            if sys.stdout.isatty():
                print("\r\033[K", end="", flush=True)

    def __exit__(self, *_):
        self.stop()
        self._thread.join()  # clean up thread only after streaming is done


def _strip_think(text):
    """Remove <think>...</think> blocks (qwen3 thinking mode)."""
    return re.sub(r"<think>.*?</think>", "", text, flags=re.DOTALL).strip()


def _is_cat_command(command_part):
    """Return True when a command segment starts with the cat command."""
    return bool(re.match(r"^cat(?:\s|$)", command_part))


def _has_output_redirection(command_part):
    """Detect shell output redirection operators in a command segment."""
    import shlex

    try:
        lexer = shlex.shlex(command_part, posix=True, punctuation_chars=True)
        lexer.whitespace_split = True
        tokens = list(lexer)
    except ValueError:
        # If parsing fails, play it safe and require confirmation.
        return True

    for token in tokens:
        if token and set(token) <= set("<>|&") and ">" in token:
            return True
    return False


def _is_safe_command(command):
    # Tokenize with shlex so | inside quoted strings isn't treated as a pipe
    import shlex
    try:
        lexer = shlex.shlex(command, posix=True, punctuation_chars=True)
        lexer.whitespace_split = True
        tokens = list(lexer)
    except ValueError:
        return False

    # Split token stream into segments on shell control operators
    segments = []
    current = []
    for tok in tokens:
        if tok in ("&&", "||", "|", ";"):
            segments.append(" ".join(current))
            current = []
        else:
            current.append(tok)
    segments.append(" ".join(current))

    for part in segments:
        part = part.strip()
        if not part:
            continue

        if _is_cat_command(part):
            if _has_output_redirection(part):
                return False
            continue

        if any(part.startswith(p) for p in SAFE_COMMAND_PREFIXES) or part.startswith(
            "cd "
        ):
            continue

        return False

    return True


def run_bash(command, confirm=False):
    if confirm and _is_safe_command(command):
        confirm = False  # auto-approve read-only commands
    if confirm:
        print(c("yellow", "\nCommand to run:"))
        print(c("bold", f"  {command}"))
        try:
            answer = input(c("yellow", "Run? [Y/n] ")).strip().lower()
        except (KeyboardInterrupt, EOFError):
            print()
            return "[Cancelled by user]"
        if answer in ("n", "no"):
            return "[Command cancelled by user]"

    try:
        result = subprocess.run(
            command,
            shell=True,
            capture_output=True,
            text=True,
            timeout=60,
        )
        output = result.stdout
        if result.stderr:
            output += result.stderr if not output else f"\n[stderr]:\n{result.stderr}"
        if result.returncode != 0:
            output += f"\n[exit code {result.returncode}]"
        return output.strip() or "(no output)"
    except subprocess.TimeoutExpired:
        return "[Timed out after 60 seconds]"
    except Exception as e:
        return f"[Error: {e}]"


def handle_tool_call(tool_call):
    name = tool_call["function"]["name"]
    args = tool_call["function"].get("arguments", {})
    if isinstance(args, str):
        try:
            args = json.loads(args)
        except Exception:
            args = {}
    command = args.get("command", "")

    if name == "bash_read":
        print(c("dim", "  [read] ") + c("bold", command))
        result = run_bash(command, confirm=not _is_safe_command(command))
    elif name == "bash":
        result = run_bash(command, confirm=True)
    elif name == "web_search":
        query = args.get("query", "")
        print(c("dim", "  [search] ") + c("bold", query))
        result = web_search(query)
    else:
        result = f"[Unknown tool: {name}]"

    cancelled = result == "[Command cancelled by user]"
    lines = result.splitlines()
    preview = "\n".join(f"  {l}" for l in lines[:20])
    if len(lines) > 20:
        preview += f"\n  ... ({len(lines) - 20} more lines)"
    print(c("dim", preview))
    print()
    return result, cancelled


def chat_request(host, model, messages, tools, stream=True, stop_spinner=None, label="AI"):
    """Returns (content, tool_calls, assistant_message) or (None, None, None) on error."""
    url = f"{host}/api/chat"
    payload = json.dumps(
        {
            "model": model,
            "messages": messages,
            "tools": tools,
            "stream": stream,
            "options": {"num_ctx": 65536},
        }
    ).encode()

    req = urllib.request.Request(
        url,
        data=payload,
        headers={"Content-Type": "application/json"},
    )

    try:
        with urllib.request.urlopen(req) as resp:
            if stream:
                full_content = ""
                all_tool_calls = []
                final_message = {}
                in_think = False
                partial = ""  # holds incomplete tag fragment across chunks
                prefix_printed = False

                for line in resp:
                    if not line:
                        continue
                    chunk = json.loads(line.decode())
                    msg = chunk.get("message", {})
                    token = msg.get("content", "")

                    if token:
                        full_content += token
                        work = partial + token
                        partial = ""
                        out = ""

                        while work:
                            if not in_think:
                                idx = work.find("<think>")
                                if idx == -1:
                                    # Check if the tail could be a partial <think>
                                    for n in range(len("<think>") - 1, 0, -1):
                                        if work.endswith("<think>"[:n]):
                                            partial = work[-n:]
                                            work = work[:-n]
                                            break
                                    out += work
                                    work = ""
                                else:
                                    out += work[:idx]
                                    work = work[idx + len("<think>") :]
                                    in_think = True
                            else:
                                idx = work.find("</think>")
                                if idx == -1:
                                    for n in range(len("</think>") - 1, 0, -1):
                                        if work.endswith("</think>"[:n]):
                                            partial = work[-n:]
                                            work = work[:-n]
                                            break
                                    work = ""
                                    break
                                else:
                                    work = work[idx + len("</think>") :]
                                    in_think = False

                        if out:
                            if not prefix_printed:
                                if stop_spinner:
                                    stop_spinner()
                                print(c("green", f"{label}: "), end="", flush=True)
                                prefix_printed = True
                            print(out, end="", flush=True)

                    chunk_tools = msg.get("tool_calls", [])
                    if chunk_tools:
                        all_tool_calls.extend(chunk_tools)

                    if chunk.get("done"):
                        final_message = msg
                        done_tools = msg.get("tool_calls", [])
                        if done_tools:
                            all_tool_calls.extend(done_tools)
                        break

                if prefix_printed:
                    print()  # newline after streamed text

                # Deduplicate tool calls (done chunk may repeat them)
                seen, unique_tool_calls = set(), []
                for tc in all_tool_calls:
                    key = json.dumps(tc, sort_keys=True)
                    if key not in seen:
                        seen.add(key)
                        unique_tool_calls.append(tc)

                for tc in unique_tool_calls:
                    if not tc["function"].get("arguments"):
                        tc["function"]["arguments"] = "{}"
                failed_tool = not prefix_printed and not unique_tool_calls

                display_content = _strip_think(full_content)
                content = final_message.get("content", "") or full_content
                assistant_msg = {"role": "assistant", "content": content}
                if unique_tool_calls:
                    assistant_msg["tool_calls"] = unique_tool_calls
                return display_content, unique_tool_calls, assistant_msg, failed_tool
            else:
                data = json.loads(resp.read().decode())
                msg = data["message"]
                tool_calls = msg.get("tool_calls", [])
                display = _strip_think(msg.get("content", ""))
                if display:
                    print(c("green", f"{label}: ") + display)
                failed_tool = not display and not tool_calls
                return display, tool_calls, msg, failed_tool

    except urllib.error.URLError as e:
        print(c("red", f"\nError connecting to Ollama at {host}: {e}"))
        print(c("dim", "Is Ollama running? Try: ollama serve"))
        return None, None, None, False


def list_models(host):
    try:
        with urllib.request.urlopen(f"{host}/api/tags") as resp:
            data = json.loads(resp.read().decode())
            return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []


def chat_loop(model, system_prompt, host, stream, preload_messages=None):
    cwd = os.getcwd()
    system_parts = [f"Working directory: {cwd}"]
    if system_prompt:
        system_parts.append(system_prompt)
    if preload_messages:
        messages = preload_messages
        # Update the system message cwd to current
        if messages and messages[0]["role"] == "system":
            messages[0]["content"] = "\n".join(system_parts)
    else:
        messages = [{"role": "system", "content": "\n".join(system_parts)}]

    print(c("bold", "ai") + c("dim", f" [{model}] ") + c("dim", cwd))
    if system_prompt:
        preview = system_prompt[:60] + ("..." if len(system_prompt) > 60 else "")
        print(c("dim", f"System: {preview}"))
    print(c("dim", "Type /help for commands, Ctrl+C or /exit to quit\n"))

    while True:
        try:
            user_input = input(c("cyan", "You: ")).strip()
        except (KeyboardInterrupt, EOFError):
            print(c("dim", "\nBye!"))
            break

        if not user_input:
            continue

        if user_input.startswith("/"):
            parts = user_input.split(None, 1)
            cmd = parts[0].lower()
            arg = parts[1] if len(parts) > 1 else ""

            if cmd in ("/exit", "/quit", "/bye"):
                print(c("dim", "Bye!"))
                break

            elif cmd == "/clear":
                system_parts = [f"Working directory: {cwd}"]
                if system_prompt:
                    system_parts.append(system_prompt)
                messages = [{"role": "system", "content": "\n".join(system_parts)}]
                print(c("dim", "Conversation cleared."))

            elif cmd == "/model":
                if arg:
                    model = arg
                    print(c("dim", f"Model set to: {model}"))
                else:
                    available = list_models(host)
                    print(c("dim", f"Current model: {model}"))
                    if available:
                        print(c("dim", "Available: " + ", ".join(available)))

            elif cmd == "/system":
                if arg:
                    system_prompt = arg
                    messages = [m for m in messages if m["role"] != "system"]
                    messages.insert(0, {"role": "system", "content": system_prompt})
                    print(c("dim", "System prompt updated."))
                else:
                    print(c("dim", f"System prompt: {system_prompt or '(none)'}"))

            elif cmd == "/history":
                for msg in messages:
                    if msg["role"] == "system":
                        continue
                    role_color = "cyan" if msg["role"] == "user" else "green"
                    label = msg["role"].title()
                    content = msg.get("content") or "[tool calls]"
                    print(c(role_color, f"{label}: ") + content)

            elif cmd == "/save":
                filename = arg or "ai-context.json"
                try:
                    with open(filename, "w") as f:
                        json.dump({"model": model, "messages": messages}, f, indent=2)
                    print(c("dim", f"Context saved to: {filename}"))
                except Exception as e:
                    print(c("red", f"Failed to save: {e}"))

            elif cmd == "/load":
                if not arg:
                    print(c("yellow", "Usage: /load <filename>"))
                else:
                    try:
                        with open(arg) as f:
                            data = json.load(f)
                        messages = data["messages"]
                        if "model" in data:
                            model = data["model"]
                        print(
                            c(
                                "dim",
                                f"Context loaded from: {arg} (model: {model}, {len(messages)} messages)",
                            )
                        )
                    except Exception as e:
                        print(c("red", f"Failed to load: {e}"))

            elif cmd == "/help":
                print(c("bold", "Commands:"))
                print("  /clear            Clear conversation history")
                print("  /model [name]     Show or set the active model")
                print("  /system [text]    Show or set the system prompt")
                print("  /history          Print conversation history")
                print(
                    "  /save [file]      Save context to file (default: ai-context.json)"
                )
                print("  /load <file>      Load context from file")
                print("  /exit             Quit")
                print()
                print(c("bold", "Tools available to the AI:"))
                print("  bash_read         Read-only commands — run automatically")
                print(
                    "  bash              Commands that change things — asks you first"
                )
                print("  web_search        Search the web via DuckDuckGo")

            else:
                print(c("yellow", f"Unknown command: {cmd}. Type /help for help."))

            continue

        messages.append({"role": "user", "content": user_input})
        user_msg_idx = len(messages) - 1

        # Agentic loop: keep going while the model is calling tools
        retry_count = 0
        max_retries = 3
        while True:
            try:
                with Spinner() as spinner:
                    content, tool_calls, assistant_msg, failed_tool = chat_request(
                        host,
                        model,
                        messages,
                        tools=TOOLS,
                        stream=stream,
                        stop_spinner=spinner.stop,
                        label=model,
                    )
            except KeyboardInterrupt:
                print(c("dim", "\n[cancelled]"))
                if messages and messages[-1]["role"] == "user":
                    messages.pop()
                break

            if assistant_msg is None:
                # Connection error — remove the user message we just added
                if messages and messages[-1]["role"] == "user":
                    messages.pop()
                break

            messages.append(assistant_msg)

            if failed_tool:
                retry_count += 1
                if retry_count >= max_retries:
                    print(
                        c("yellow", f"AI: (no response after {max_retries} attempts)")
                    )
                    break
                print(
                    c("dim", f"No response, retrying... ({retry_count}/{max_retries})")
                )
                messages.append(
                    {
                        "role": "user",
                        "content": "It seems you didn't produce a response. Please continue.",
                    }
                )
                continue

            retry_count = 0  # reset on successful response

            if not tool_calls:
                break

            print()  # blank line before tool output
            cancelled = False
            try:
                for tool_call in tool_calls:
                    result, was_cancelled = handle_tool_call(tool_call)
                    messages.append({"role": "tool", "content": result})
                    if was_cancelled:
                        cancelled = True
                        break
            except KeyboardInterrupt:
                del messages[user_msg_idx:]
                print(c("dim", "\n[cancelled]"))
                break

            if cancelled:
                try:
                    follow_up = input(c("cyan", "You: ")).strip()
                except (KeyboardInterrupt, EOFError):
                    print(c("dim", "\nBye!"))
                    return
                if follow_up in ("/exit", "/quit", "/bye"):
                    print(c("dim", "Bye!"))
                    return
                messages.append({"role": "user", "content": follow_up})
                continue


def main():
    parser = argparse.ArgumentParser(
        description="Interactive AI chat powered by Ollama",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Environment variables:
  OLLAMA_MODEL   Default model to use
  OLLAMA_HOST    Ollama server URL (default: http://localhost:11434)
  OLLAMA_SYSTEM  Default system prompt

Examples:
  ai                                    Start chat (auto-picks first available model)
  ai -m qwen3:4b                        Use a specific model
  ai -s "You are a Linux expert"        Set a system prompt
  ai --list                             List available models
  OLLAMA_MODEL=qwen3:4b ai              Set model via env var
""",
    )
    parser.add_argument(
        "-m",
        "--model",
        default=os.environ.get("OLLAMA_MODEL", "qwen3.5:9b-q8_0"),
        help="Model to use (or set OLLAMA_MODEL env var)",
    )
    parser.add_argument(
        "-s",
        "--system",
        default=os.environ.get(
            "OLLAMA_SYSTEM",
            "When editing existing files, prefer targeted edits (sed, patch, line insertions) over full rewrites unless the change is large. After making changes, always verify them by running or testing the code to confirm it works correctly.",
        ),
        help="System prompt (or set OLLAMA_SYSTEM env var)",
    )
    parser.add_argument(
        "--host",
        default=os.environ.get("OLLAMA_HOST", DEFAULT_HOST),
        help="Ollama host URL (default: http://localhost:11434)",
    )
    parser.add_argument(
        "--no-stream",
        action="store_true",
        help="Disable streaming output",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="List available models and exit",
    )
    parser.add_argument(
        "-l",
        "--load",
        metavar="FILE",
        help="Load a saved context file to resume a previous session",
    )

    args = parser.parse_args()

    if args.list:
        models = list_models(args.host)
        if models:
            print(c("bold", "Available models:"))
            for m in models:
                print(f"  {m}")
        else:
            print(c("yellow", f"No models found or couldn't connect to {args.host}"))
        return

    preload_messages = None
    if args.load:
        try:
            with open(args.load) as f:
                data = json.load(f)
            preload_messages = data.get("messages")
            if not args.model and "model" in data:
                args.model = data["model"]
            print(c("dim", f"Resuming context from: {args.load}"))
        except Exception as e:
            print(c("red", f"Failed to load context: {e}"))

    chat_loop(
        model=args.model,
        system_prompt=args.system,
        host=args.host,
        stream=not args.no_stream,
        preload_messages=preload_messages,
    )


if __name__ == "__main__":
    main()
