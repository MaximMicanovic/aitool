#!/usr/bin/env python3
"""ai - Interactive chat tool for local model backends."""

import argparse
import json
import os
import re
import sys
import threading
import time
import urllib.error
import urllib.request

from startup import startup_sequence
from tools import TOOLS, handle_tool_call

COLORS = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "cyan": "\033[36m",
    "green": "\033[32m",
    "yellow": "\033[33m",
    "red": "\033[31m",
    "magenta": "\033[35m",
}

def c(color, text):
    if sys.stdout.isatty():
        return f"{COLORS.get(color, '')}{text}{COLORS['reset']}"
    return text


class Spinner:
    _frames = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

    def __init__(self, label="Thinking"):
        self._label = label
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._spin, daemon=True)

    def _spin(self):
        if not sys.stdout.isatty():
            return
        i = 0
        while not self._stop.is_set():
            frame = self._frames[i % len(self._frames)]
            print(
                f"\r{c('dim', frame + ' ' + self._label + '...')}", end="", flush=True
            )
            i += 1
            time.sleep(0.08)

    def __enter__(self):
        self._thread.start()
        return self

    def stop(self):
        """Non-blocking stop: signal thread and clear line immediately."""
        if not self._stop.is_set():
            self._stop.set()
            if sys.stdout.isatty():
                print("\r\033[K", end="", flush=True)

    def __exit__(self, *_):
        self.stop()
        self._thread.join()  # clean up thread only after streaming is done


def _strip_think(text):
    """Remove <think>...</think> blocks (qwen3 thinking mode)."""
    return re.sub(r"<think>.*?</think>", "", text, flags=re.DOTALL).strip()


def chat_request(
    host,
    model,
    messages,
    tools,
    stream=True,
    stop_spinner=None,
    label="AI",
    provider="ollama",
):
    """Returns (content, tool_calls, assistant_message, failed_tool, response_model)."""
    if provider == "lmstudio":
        # LM Studio exposes an OpenAI-compatible chat endpoint.
        url = f"{host}/v1/chat/completions"
        payload = json.dumps(
            {
                "model": model,
                "messages": messages,
                "tools": tools,
                "stream": stream,
            }
        ).encode()
    else:
        url = f"{host}/api/chat"
        payload = json.dumps(
            {
                "model": model,
                "messages": messages,
                "tools": tools,
                "stream": stream,
                "options": {"num_ctx": 65536},
            }
        ).encode()

    req = urllib.request.Request(
        url,
        data=payload,
        headers={"Content-Type": "application/json"},
    )

    try:
        with urllib.request.urlopen(req) as resp:
            if stream:
                full_content = ""
                response_model = None
                in_think = False
                partial = ""  # holds incomplete tag fragment across chunks
                prefix_printed = False

                if provider == "lmstudio":
                    # OpenAI-style SSE streaming.
                    tool_buffers = {}

                    for raw_line in resp:
                        if not raw_line:
                            continue
                        line = raw_line.decode(errors="ignore").strip()
                        if not line or not line.startswith("data:"):
                            continue

                        data_part = line[len("data:") :].strip()
                        if data_part == "[DONE]":
                            break

                        try:
                            chunk = json.loads(data_part)
                        except json.JSONDecodeError:
                            continue

                        if not response_model:
                            response_model = chunk.get("model")

                        choices = chunk.get("choices", [])
                        if not choices:
                            continue
                        delta = choices[0].get("delta", {})
                        token = delta.get("content", "")

                        if token:
                            full_content += token
                            work = partial + token
                            partial = ""
                            out = ""

                            while work:
                                if not in_think:
                                    idx = work.find("<think>")
                                    if idx == -1:
                                        # Check if the tail could be a partial <think>
                                        for n in range(len("<think>") - 1, 0, -1):
                                            if work.endswith("<think>"[:n]):
                                                partial = work[-n:]
                                                work = work[:-n]
                                                break
                                        out += work
                                        work = ""
                                    else:
                                        out += work[:idx]
                                        work = work[idx + len("<think>") :]
                                        in_think = True
                                else:
                                    idx = work.find("</think>")
                                    if idx == -1:
                                        for n in range(len("</think>") - 1, 0, -1):
                                            if work.endswith("</think>"[:n]):
                                                partial = work[-n:]
                                                work = work[:-n]
                                                break
                                        work = ""
                                        break
                                    else:
                                        work = work[idx + len("</think>") :]
                                        in_think = False

                            if out:
                                if not prefix_printed:
                                    if stop_spinner:
                                        stop_spinner()
                                    print(
                                        c("green", f"{response_model or label}: "),
                                        end="",
                                        flush=True,
                                    )
                                    prefix_printed = True
                                print(out, end="", flush=True)

                        for tc in delta.get("tool_calls", []):
                            idx = tc.get("index", 0)
                            if idx not in tool_buffers:
                                tool_buffers[idx] = {
                                    "id": tc.get("id", ""),
                                    "type": "function",
                                    "function": {"name": "", "arguments": ""},
                                }
                            entry = tool_buffers[idx]
                            if tc.get("id"):
                                entry["id"] = tc["id"]
                            fn = tc.get("function", {})
                            if fn.get("name"):
                                entry["function"]["name"] = fn["name"]
                            if fn.get("arguments"):
                                entry["function"]["arguments"] += fn["arguments"]

                    if prefix_printed:
                        print()  # newline after streamed text

                    tool_calls = [tool_buffers[k] for k in sorted(tool_buffers)]
                    for tc in tool_calls:
                        if not tc["function"].get("arguments"):
                            tc["function"]["arguments"] = "{}"

                    failed_tool = not prefix_printed and not tool_calls
                    display_content = _strip_think(full_content)
                    assistant_msg = {"role": "assistant", "content": full_content}
                    if tool_calls:
                        assistant_msg["tool_calls"] = tool_calls
                    return (
                        display_content,
                        tool_calls,
                        assistant_msg,
                        failed_tool,
                        response_model,
                    )
                else:
                    all_tool_calls = []
                    final_message = {}

                    for line in resp:
                        if not line:
                            continue
                        chunk = json.loads(line.decode())
                        if not response_model:
                            response_model = chunk.get("model")
                        msg = chunk.get("message", {})
                        token = msg.get("content", "")

                        if token:
                            full_content += token
                            work = partial + token
                            partial = ""
                            out = ""

                            while work:
                                if not in_think:
                                    idx = work.find("<think>")
                                    if idx == -1:
                                        # Check if the tail could be a partial <think>
                                        for n in range(len("<think>") - 1, 0, -1):
                                            if work.endswith("<think>"[:n]):
                                                partial = work[-n:]
                                                work = work[:-n]
                                                break
                                        out += work
                                        work = ""
                                    else:
                                        out += work[:idx]
                                        work = work[idx + len("<think>") :]
                                        in_think = True
                                else:
                                    idx = work.find("</think>")
                                    if idx == -1:
                                        for n in range(len("</think>") - 1, 0, -1):
                                            if work.endswith("</think>"[:n]):
                                                partial = work[-n:]
                                                work = work[:-n]
                                                break
                                        work = ""
                                        break
                                    else:
                                        work = work[idx + len("</think>") :]
                                        in_think = False

                            if out:
                                if not prefix_printed:
                                    if stop_spinner:
                                        stop_spinner()
                                    print(
                                        c("green", f"{response_model or label}: "),
                                        end="",
                                        flush=True,
                                    )
                                    prefix_printed = True
                                print(out, end="", flush=True)

                        chunk_tools = msg.get("tool_calls", [])
                        if chunk_tools:
                            all_tool_calls.extend(chunk_tools)

                        if chunk.get("done"):
                            final_message = msg
                            done_tools = msg.get("tool_calls", [])
                            if done_tools:
                                all_tool_calls.extend(done_tools)
                            break

                    if prefix_printed:
                        print()  # newline after streamed text

                    # Deduplicate tool calls (done chunk may repeat them)
                    seen, unique_tool_calls = set(), []
                    for tc in all_tool_calls:
                        key = json.dumps(tc, sort_keys=True)
                        if key not in seen:
                            seen.add(key)
                            unique_tool_calls.append(tc)

                    for tc in unique_tool_calls:
                        if not tc["function"].get("arguments"):
                            tc["function"]["arguments"] = "{}"
                    failed_tool = not prefix_printed and not unique_tool_calls

                    display_content = _strip_think(full_content)
                    content = final_message.get("content", "") or full_content
                    assistant_msg = {"role": "assistant", "content": content}
                    if unique_tool_calls:
                        assistant_msg["tool_calls"] = unique_tool_calls
                    return (
                        display_content,
                        unique_tool_calls,
                        assistant_msg,
                        failed_tool,
                        response_model,
                    )
            else:
                data = json.loads(resp.read().decode())
                if provider == "lmstudio":
                    choices = data.get("choices", [])
                    msg = choices[0].get("message", {}) if choices else {}
                    response_model = data.get("model")
                else:
                    msg = data["message"]
                    response_model = data.get("model")
                tool_calls = msg.get("tool_calls", [])
                display = _strip_think(msg.get("content", ""))
                if display:
                    if stop_spinner:
                        stop_spinner()
                    print(c("green", f"{response_model or label}: ") + display)
                failed_tool = not display and not tool_calls
                return display, tool_calls, msg, failed_tool, response_model

    except urllib.error.URLError as e:
        print(c("red", f"\nError connecting to backend at {host}: {e}"))
        return None, None, None, False, None


def list_models(host, provider="ollama"):
    try:
        if provider == "lmstudio":
            with urllib.request.urlopen(f"{host}/v1/models") as resp:
                data = json.loads(resp.read().decode())
                return [m["id"] for m in data.get("data", []) if "id" in m]
        with urllib.request.urlopen(f"{host}/api/tags") as resp:
            data = json.loads(resp.read().decode())
            return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []


def resolve_boot_model_name(requested_model, host, provider):
    """Resolve the startup model label from backend metadata when possible."""
    models = list_models(host, provider=provider)
    if not models:
        return requested_model
    if requested_model in models:
        return requested_model
    base = requested_model.split(":", 1)[0].strip().lower()
    if base:
        matches = [m for m in models if base in m.lower()]
        if len(matches) == 1:
            return matches[0]
    if len(models) == 1:
        return models[0]
    return requested_model


def select_model_interactively(models, current_model=None):
    """Ask user to choose a model from available options."""
    current_model = current_model if current_model in models else None
    print(c("bold", "Available models:"))
    for i, name in enumerate(models, 1):
        marker = " (current)" if current_model and name == current_model else ""
        print(f"  {i}. {name}{marker}")

    while True:
        prompt = "Select model by number or name: "
        try:
            choice = input(c("cyan", prompt)).strip()
        except (KeyboardInterrupt, EOFError):
            print()
            return current_model or models[0]

        if not choice:
            return current_model or models[0]
        if choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(models):
                return models[idx - 1]
        if choice in models:
            return choice
        print(c("yellow", "Invalid selection. Please try again."))


def handle_slash_command(user_input, model, system_prompt, messages, cwd, host, provider):
    parts = user_input.split(None, 1)
    cmd = parts[0].lower()
    arg = parts[1] if len(parts) > 1 else ""

    if cmd in ("/exit", "/quit", "/bye"):
        print(c("dim", "Bye!"))
        return model, system_prompt, messages, True

    if cmd == "/clear":
        system_parts = [f"Working directory: {cwd}"]
        if system_prompt:
            system_parts.append(system_prompt)
        messages = [{"role": "system", "content": "\n".join(system_parts)}]
        print(c("dim", "Conversation cleared."))
    elif cmd == "/model":
        if arg:
            model = arg
            print(c("dim", f"Model set to: {model}"))
        else:
            available = list_models(host, provider=provider)
            print(c("dim", f"Current model: {model}"))
            if available:
                print(c("dim", "Available: " + ", ".join(available)))
    elif cmd == "/system":
        if arg:
            system_prompt = arg
            messages = [m for m in messages if m["role"] != "system"]
            messages.insert(0, {"role": "system", "content": system_prompt})
            print(c("dim", "System prompt updated."))
        else:
            print(c("dim", f"System prompt: {system_prompt or '(none)'}"))
    elif cmd == "/history":
        for msg in messages:
            if msg["role"] == "system":
                continue
            role_color = "cyan" if msg["role"] == "user" else "green"
            label = msg["role"].title()
            content = msg.get("content") or "[tool calls]"
            print(c(role_color, f"{label}: ") + content)
    elif cmd == "/save":
        filename = arg or "ai-context.json"
        try:
            with open(filename, "w") as f:
                json.dump({"model": model, "messages": messages}, f, indent=2)
            print(c("dim", f"Context saved to: {filename}"))
        except Exception as e:
            print(c("red", f"Failed to save: {e}"))
    elif cmd == "/load":
        if not arg:
            print(c("yellow", "Usage: /load <filename>"))
        else:
            try:
                with open(arg) as f:
                    data = json.load(f)
                messages = data["messages"]
                if "model" in data:
                    model = data["model"]
                print(
                    c(
                        "dim",
                        f"Context loaded from: {arg} (model: {model}, {len(messages)} messages)",
                    )
                )
            except Exception as e:
                print(c("red", f"Failed to load: {e}"))
    elif cmd == "/help":
        print(c("bold", "Commands:"))
        print("  /clear            Clear conversation history")
        print("  /model [name]     Show or set the active model")
        print("  /system [text]    Show or set the system prompt")
        print("  /history          Print conversation history")
        print("  /save [file]      Save context to file (default: ai-context.json)")
        print("  /load <file>      Load context from file")
        print("  /exit             Quit")
        print()
        print(c("bold", "Tools available to the AI:"))
        print("  bash_read         Read-only commands — run automatically")
        print("  bash              Commands that change things — asks you first")
        print("  web_search        Search the web via DuckDuckGo")
    else:
        print(c("yellow", f"Unknown command: {cmd}. Type /help for help."))

    return model, system_prompt, messages, False


def chat_loop(model, system_prompt, host, stream, preload_messages=None, provider="ollama"):
    cwd = os.getcwd()
    system_parts = [f"Working directory: {cwd}"]
    if system_prompt:
        system_parts.append(system_prompt)
    if preload_messages:
        messages = preload_messages
        # Update the system message cwd to current
        if messages and messages[0]["role"] == "system":
            messages[0]["content"] = "\n".join(system_parts)
    else:
        messages = [{"role": "system", "content": "\n".join(system_parts)}]

    boot_model_name = resolve_boot_model_name(model, host, provider)
    print(c("bold", "ai") + c("dim", f" [{boot_model_name}] ") + c("dim", cwd))
    backend_label = "LM Studio" if provider == "lmstudio" else "Ollama"
    print(c("dim", f"Backend: {backend_label} ({host})"))
    if system_prompt:
        preview = system_prompt[:60] + ("..." if len(system_prompt) > 60 else "")
        print(c("dim", f"System: {preview}"))
    print(c("dim", "Type /help for commands, Ctrl+C or /exit to quit\n"))

    while True:
        try:
            user_input = input(c("cyan", "You: ")).strip()
        except (KeyboardInterrupt, EOFError):
            print(c("dim", "\nBye!"))
            break

        if not user_input:
            continue

        if user_input.startswith("/"):
            model, system_prompt, messages, should_exit = handle_slash_command(
                user_input=user_input,
                model=model,
                system_prompt=system_prompt,
                messages=messages,
                cwd=cwd,
                host=host,
                provider=provider,
            )
            if should_exit:
                break
            continue

        messages.append({"role": "user", "content": user_input})
        user_msg_idx = len(messages) - 1

        # Agentic loop: keep going while the model is calling tools
        retry_count = 0
        max_retries = 3
        while True:
            try:
                with Spinner() as spinner:
                    content, tool_calls, assistant_msg, failed_tool, _ = chat_request(
                        host,
                        model,
                        messages,
                        tools=TOOLS,
                        stream=stream,
                        stop_spinner=spinner.stop,
                        label=model,
                        provider=provider,
                    )
            except KeyboardInterrupt:
                print(c("dim", "\n[cancelled]"))
                if messages and messages[-1]["role"] == "user":
                    messages.pop()
                break

            if assistant_msg is None:
                # Connection error — remove the user message we just added
                if messages and messages[-1]["role"] == "user":
                    messages.pop()
                break

            messages.append(assistant_msg)

            if failed_tool:
                retry_count += 1
                if retry_count >= max_retries:
                    print(
                        c("yellow", f"AI: (no response after {max_retries} attempts)")
                    )
                    break
                print(
                    c("dim", f"No response, retrying... ({retry_count}/{max_retries})")
                )
                messages.append(
                    {
                        "role": "user",
                        "content": "It seems you didn't produce a response. Please continue.",
                    }
                )
                continue

            retry_count = 0  # reset on successful response

            if not tool_calls:
                break

            print()  # blank line before tool output
            cancelled = False
            try:
                for tool_call in tool_calls:
                    result, was_cancelled = handle_tool_call(tool_call, c=c)
                    messages.append({"role": "tool", "content": result})
                    if was_cancelled:
                        cancelled = True
                        break
            except KeyboardInterrupt:
                del messages[user_msg_idx:]
                print(c("dim", "\n[cancelled]"))
                break

            if cancelled:
                try:
                    follow_up = input(c("cyan", "You: ")).strip()
                except (KeyboardInterrupt, EOFError):
                    print(c("dim", "\nBye!"))
                    return
                if follow_up in ("/exit", "/quit", "/bye"):
                    print(c("dim", "Bye!"))
                    return
                messages.append({"role": "user", "content": follow_up})
                continue


def main():
    parser = argparse.ArgumentParser(
        description="Interactive AI chat for local backends (Ollama/LM Studio)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Environment variables:
  OLLAMA_HOST    Ollama server URL (default on Linux: http://localhost:11434)
  LM_STUDIO_HOST LM Studio URL (default on WSL: http://192.168.1.56:1234)
  AI_PROVIDER    Force provider: ollama or lmstudio
  OLLAMA_SYSTEM  Default system prompt

Examples:
  ai                                    Start chat (auto-picks first available model)
  ai -m qwen3.5:9b-q8_0                 Use a specific model
  ai -s "You are a Linux expert"        Set a system prompt
  ai --list                             List available models
""",
    )
    parser.add_argument(
        "-m",
        "--model",
        default=None,
        help="Model to use",
    )
    parser.add_argument(
        "-s",
        "--system",
        default=os.environ.get(
            "OLLAMA_SYSTEM",
            "When editing existing files, prefer targeted edits (sed, patch, line insertions) over full rewrites unless the change is large. After making changes, always verify them by running or testing the code to confirm it works correctly.",
        ),
        help="System prompt (or set OLLAMA_SYSTEM env var)",
    )
    parser.add_argument(
        "--host",
        default=None,
        help="Backend host URL (auto-detected by startup sequence if omitted)",
    )
    parser.add_argument(
        "--no-stream",
        action="store_true",
        help="Disable streaming output",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="List available models and exit",
    )
    parser.add_argument(
        "-l",
        "--load",
        metavar="FILE",
        help="Load a saved context file to resume a previous session",
    )

    args = parser.parse_args()
    startup = startup_sequence(args.host)
    args.host = startup.host
    available_models = list_models(args.host, provider=startup.provider)

    if args.list:
        if available_models:
            print(c("bold", "Available models:"))
            for m in available_models:
                print(f"  {m}")
        else:
            print(c("yellow", f"No models found or couldn't connect to {args.host}"))
        return

    if available_models:
        if len(available_models) == 1:
            args.model = available_models[0]
        elif not args.model or args.model not in available_models:
            if sys.stdin.isatty():
                args.model = select_model_interactively(
                    available_models, current_model=args.model
                )
            else:
                args.model = available_models[0]
    elif not args.model:
        print(c("yellow", "No model configured and no models detected from backend."))
        return

    preload_messages = None
    if args.load:
        try:
            with open(args.load) as f:
                data = json.load(f)
            preload_messages = data.get("messages")
            if not args.model and "model" in data:
                args.model = data["model"]
            print(c("dim", f"Resuming context from: {args.load}"))
        except Exception as e:
            print(c("red", f"Failed to load context: {e}"))

    chat_loop(
        model=args.model,
        system_prompt=args.system,
        host=args.host,
        stream=not args.no_stream,
        preload_messages=preload_messages,
        provider=startup.provider,
    )


if __name__ == "__main__":
    main()
